# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Supabase (get from supabase.com → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Frontend URL (for CORS — your Vercel URL)
FRONTEND_URL=https://your-app.vercel.app

# API Keys (Phase 2)
TICKETMASTER_API_KEY=your-ticketmaster-consumer-key
EVENTBRITE_API_KEY=your-eventbrite-private-token
BANDSINTOWN_APP_ID=your-bandsintown-app-id
SONGKICK_API_KEY=your-songkick-api-key

# Email (Phase 3)
RESEND_API_KEY=your-resend-api-key

# Map (Phase 5)
MAPBOX_SECRET_TOKEN=your-mapbox-secret-token

# AI (Phase 6)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Push Notifications (Phase 7)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Admin
ADMIN_PASSWORD=choose-a-strong-password

# Stripe (Phase 8)
STRIPE_SECRET_KEY=your-stripe-secret-key

PORT=3001
